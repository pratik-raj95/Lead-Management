# Port Configuration
PORT=5000
CORS_ORIGIN=*

# Google Sheets API Credentials
# Note: Share your spreadsheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-from-url

# Meta Apps & Graph API Credentials
# Used for Facebook Lead Ads query & WhatsApp Cloud API outgoing dispatches
META_ACCESS_TOKEN=your-facebook-app-system-user-access-token
META_VERIFY_TOKEN=your-webhook-verification-token-for-handshake

# WhatsApp Business Cloud API Settings
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token

# Google Ads Integration Settings
GOOGLE_ADS_KEY=your-google-webhook-authentication-key

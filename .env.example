# =========================================================================
# Antigravity CRM Configuration Template
# =========================================================================

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION (frontend/.env)
# -------------------------------------------------------------------------
# Deployed base URL of the Express API server (port 5000)
VITE_API_URL=http://localhost:5000

# -------------------------------------------------------------------------
# BACKEND CONFIGURATION (backend/.env)
# -------------------------------------------------------------------------
PORT=5000
CORS_ORIGIN=*

# Google Sheets Database Authentication
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-from-url

# Meta Apps & Graph API
META_ACCESS_TOKEN=your-facebook-app-system-user-access-token
META_VERIFY_TOKEN=crm_meta_token

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=crm_whatsapp_token

# Google Ads Integration
GOOGLE_ADS_KEY=crm_google_key
